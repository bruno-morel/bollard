{
  "name": "bollard",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Artifact integrity framework for AI-assisted software development",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "vite": ">=7.3.2",
      "hono": ">=4.12.18",
      "@hono/node-server": ">=1.19.13",
      "fast-uri": ">=3.1.2",
      "postcss": ">=8.5.10",
      "ip-address": ">=10.1.1",
      "brace-expansion": ">=5.0.6",
      "qs": ">=6.15.2",
      "vitest@<4.1.0": ">=4.1.0"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "fast-check": "^3.23.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
