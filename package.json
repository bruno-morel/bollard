{
  "name": "bollard",
  "version": "0.0.1",
  "private": true,
  "description": "Artifact integrity framework for AI-assisted software development",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ],
    "overrides": {
      "vite": ">=7.3.2",
      "hono": ">=4.12.14",
      "@hono/node-server": ">=1.19.13"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/node": "^25.5.0",
    "fast-check": "^3.23.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
