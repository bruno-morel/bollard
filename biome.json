{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "asNeeded",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "useLiteralKeys": "off"
      },
      "style": {
        "noDefaultExport": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "**/vitest.config.ts",
        "**/vitest.adversarial.config.ts",
        "**/vitest.contract.config.ts",
        "**/vitest.stryker.config.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    }
  ],
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/.bollard",
      "!**/*.json",
      "!**/*.d.ts",
      "!**/*.js",
      "!**/*.map",
      "!**/*.adversarial.test.ts",
      "!**/.stryker-tmp"
    ]
  }
}
