    "generate-tests": {
      "status": "ok",
      "data": "```java\npackage com.example.core;\n\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.params.ParameterizedTest;\nimport org.junit.jupiter.params.provider.CsvSource;\nimport org.junit.jupiter.params.provider.ValueSource;\nimport static org.junit.jupiter.api.Assertions.*;\n\npublic class CalculatorAdversarialTest {\n\n    @Test\n    void shouldReturnEightForTwoToThePowerOfThree() {\n        Calculator calc = new Calculator();\n        double result = calc.power(2, 3);\n        assertEquals(8.0, result, 0.0001);\n    }\n\n    @Test\n    void shouldReturnOneForAnyBaseToThePowerOfZero() {\n        Calculator calc = new Calculator();\n        assertEquals(1.0, calc.power(5, 0), 0.0001);\n        assertEquals(1.0, calc.power(0, 0), 0.0001);\n        assertEquals(1.0, calc.power(-3, 0), 0.0001);\n        assertEquals(1.0, calc.power(Integer.MAX_VALUE, 0), 0.0001);\n        assertEquals(1.0, calc.power(Integer.MIN_VALUE, 0), 0.0001);\n    }\n\n    @Test\n    void shouldReturnPointOneTwoFiveForTwoToThePowerOfNegativeThree() {\n        Calculator calc = new Calculator();\n        double result = calc.power(2, -3);\n        assertEquals(0.125, result, 0.0001);\n    }\n\n    @Test\n    void shouldThrowIllegalArgumentExceptionForZeroBaseAndNegativeExponent() {\n        Calculator calc = new Calculator();\n        IllegalArgumentException exception = assertThrows(\n            IllegalArgumentException.class,\n            () -> calc.power(0, -1)\n        );\n        assertNotNull(exception.getMessage());\n    }\n\n    @ParameterizedTest\n    @ValueSource(ints = {-1, -2, -5, -10, Integer.MIN_VALUE})\n    void shouldThrowIllegalArgumentExceptionForZeroBaseAndAnyNegativeExponent(int negativeExponent) {\n        Calculator calc = new Calculator();\n        assertThrows(IllegalArgumentException.class, () -> calc.power(0, negativeExponent));\n    }\n\n    @ParameterizedTest\n    @CsvSource({\n        \"3, 2, 9.0\",\n        \"4, 3, 64.0\",\n        \"-2, 3, -8.0\",\n        \"-3, 2, 9.0\",\n        \"1, 100, 1.0\",\n        \"-1, 5, -1.0\",\n        \"-1, 4, 1.0\"\n    })\n    void shouldCalculatePositiveExponentsProperly(int base, int exponent, double expected) {\n        Calculator calc = new Calculator();\n        assertEquals(expected, calc.power(base, exponent), 0.0001);\n    }\n\n    @ParameterizedTest\n    @CsvSource({\n        \"2, -1, 0.5\",\n        \"4, -2, 0.0625\",\n        \"10, -3, 0.001\",\n        \"-2, -2, 0.25\",\n        \"-3, -3, -0.037037037\"\n    })\n    void shouldCalculateNegativeExponentsProperly(int base, int exponent, double expected) {\n        Calculator calc = new Calculator();\n        assertEquals(expected, calc.power(base, exponent), 0.0001);\n    }\n\n    @Test\n    void shouldHandleNegativeBaseWithOddExponent() {\n        Calculator calc = new Calculator();\n        assertEquals(-8.0, calc.power(-2, 3), 0.0001);\n        assertEquals(-27.0, calc.power(-3, 3), 0.0001);\n    }\n\n    @Test\n    void shouldHandleNegativeBaseWithEvenExponent() {\n        Calculator calc = new Calculator();\n        assertEquals(4.0, calc.power(-2, 2), 0.0001);\n        assertEquals(9.0, calc.power(-3, 2), 0.0001);\n    }\n\n    @Test\n    void shouldHandleLargeExponents() {\n        Calculator calc = new Calculator();\n        assertEquals(1024.0, calc.power(2, 10), 0.0001);\n        assertEquals(0.0009765625, calc.power(2, -10), 0.0001);\n    }\n\n    @Test\n    void shouldHandleEdgeCasesForBaseOne() {\n        Calculator calc = new Calculator();\n        assertEquals(1.0, calc.power(1, Integer.MAX_VALUE), 0.0001);\n        assertEquals(1.0, calc.power(1, Integer.MIN_VALUE), 0.0001);\n        assertEquals(1.0, calc.power(1, -1000), 0.0001);\n    }\n\n    @Test\n    void shouldHandleEdgeCasesForBaseNegativeOne() {\n        Calculator calc = new Calculator();\n        assertEquals(-1.0, calc.power(-1, 1), 0.0001);\n        assertEquals(1.0, calc.power(-1, 2), 0.0001);\n        assertEquals(-1.0, calc.power(-1, -1), 0.0001);\n        assertEquals(1.0, calc.power(-1, -2), 0.0001);\n    }\n}\n```",
