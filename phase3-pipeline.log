e facade = new CalculatorFacade();\\n  Calculator calculator = new Calculator();\\n  \\n  double facadeResult = facade.computePower(2, -3);\\n  double calculatorResult = calculator.power(2, -3);\\n  \\n  assertEquals(calculatorResult, facadeResult, 0.0001);\\n  assertEquals(0.125, facadeResult, 0.0001);\\n})\"\n    },\n    {\n      \"id\": \"c3\",\n      \"concern\": \"resilience\",\n      \"claim\": \"CalculatorFacade.computePower propagates IllegalArgumentException from Calculator.power for invalid inputs\",\n      \"grounding\": [\n        {\n          \"quote\": \"public double computePower(int base, int exponent) { ... }\",\n          \"source\": \"signature:CalculatorFacade.computePower\"\n        },\n        {\n          \"quote\": \"public double power(int base, int exponent) { ... }\",\n          \"source\": \"signature:Calculator.power\"\n        }\n      ],\n      \"test\": \"import com.example.api.CalculatorFacade;\\nimport com.example.core.Calculator;\\n\\nit('computePower propagates IllegalArgumentException from Calculator.power', () -> {\\n  CalculatorFacade facade = new CalculatorFacade();\\n  Calculator calculator = new Calculator();\\n  \\n  assertThrows(IllegalArgumentException.class, () -> calculator.power(0, -1));\\n  assertThrows(IllegalArgumentException.class, () -> facade.computePower(0, -1));\\n})\"\n    },\n    {\n      \"id\": \"c4\",\n      \"concern\": \"correctness\",\n      \"claim\": \"CalculatorFacade maintains existing functionality while adding computePower delegation\",\n      \"grounding\": [\n        {\n          \"quote\": \"public int compute(String op, int a, int b) { ... }\",\n          \"source\": \"signature:CalculatorFacade.compute\"\n        },\n        {\n          \"quote\": \"public boolean checkPrime(int n) { ... }\",\n          \"source\": \"signature:CalculatorFacade.checkPrime\"\n        },\n        {\n          \"quote\": \"import com.example.core.Calculator;\\nimport com.example.core.MathUtils;\",\n          \"source\": \"edge:api->core\"\n        }\n      ],\n      \"test\": \"import com.example.api.CalculatorFacade;\\n\\nit('existing CalculatorFacade methods still work after adding computePower', () -> {\\n  CalculatorFacade facade = new CalculatorFacade();\\n  \\n  assertEquals(7, facade.compute(\\\"add\\\", 3, 4));\\n  assertEquals(12, facade.compute(\\\"multiply\\\", 3, 4));\\n  assertTrue(facade.checkPrime(7));\\n  assertFalse(facade.checkPrime(8));\\n})\"\n    },\n    {\n      \"id\": \"c5\",\n      \"concern\": \"correctness\",\n      \"claim\": \"Calculator.power returns double type compatible with CalculatorFacade.computePower return type\",\n      \"grounding\": [\n        {\n          \"quote\": \"public double power(int base, int exponent) { ... }\",\n          \"source\": \"signature:Calculator.power\"\n        },\n        {\n          \"quote\": \"public double computePower(int base, int exponent) { ... }\",\n          \"source\": \"signature:CalculatorFacade.computePower\"\n        }\n      ],\n      \"test\": \"import com.example.api.CalculatorFacade;\\nimport com.example.core.Calculator;\\n\\nit('Calculator.power and CalculatorFacade.computePower have compatible return types', () -> {\\n  Calculator calculator = new Calculator();\\n  CalculatorFacade facade = new CalculatorFacade();\\n  \\n  double calculatorResult = calculator.power(5, 0);\\n  double facadeResult = facade.computePower(5, 0);\\n  \\n  assertEquals(Double.class, Double.valueOf(calculatorResult).getClass());\\n  assertEquals(Double.class, Double.valueOf(facadeResult).getClass());\\n  assertEquals(1.0, calculatorResult, 0.0001);\\n  assertEquals(1.0, facadeResult, 0.0001);\\n})\"\n    }\n  ]\n}\n```",
