      "status": "ok",
      "data": "```java\npackage com.example.core;\n\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.params.ParameterizedTest;\nimport org.junit.jupiter.params.provider.ValueSource;\nimport org.junit.jupiter.params.provider.CsvSource;\nimport static org.junit.jupiter.api.Assertions.*;\n\npublic class CalculatorAdversarialTest {\n    \n    private final Calculator calculator = new Calculator();\n    \n    @Test\n    void shouldReturn8WhenBase2AndExponent3() {\n        assertEquals(8, calculator.power(2, 3));\n    }\n    \n    @Test\n    void shouldReturn1WhenBase5AndExponent0() {\n        assertEquals(1, calculator.power(5, 0));\n    }\n    \n    @Test\n    void shouldReturn0WhenBase0AndExponent5() {\n        assertEquals(0, calculator.power(0, 5));\n    }\n    \n    @Test\n    void shouldReturn1WhenBase1AndExponent100() {\n        assertEquals(1, calculator.power(1, 100));\n    }\n    \n    @Test\n    void shouldThrowIllegalArgumentExceptionForNegativeExponent() {\n        IllegalArgumentException exception = assertThrows(\n            IllegalArgumentException.class,\n            () -> calculator.power(2, -1)\n        );\n        assertTrue(exception.getMessage().contains(\"negative\"));\n    }\n    \n    @ParameterizedTest\n    @ValueSource(ints = {-1, -2, -10, -100})\n    void shouldThrowIllegalArgumentExceptionForAllNegativeExponents(int negativeExponent) {\n        IllegalArgumentException exception = assertThrows(\n            IllegalArgumentException.class,\n            () -> calculator.power(5, negativeExponent)\n        );\n        assertTrue(exception.getMessage().contains(\"negative\"));\n    }\n    \n    @ParameterizedTest\n    @ValueSource(ints = {0, 1, 2, 3, 10, 100, 1000})\n    void shouldReturnOneForAnyBaseToZeroPower(int base) {\n        assertEquals(1, calculator.power(base, 0));\n    }\n    \n    @ParameterizedTest\n    @ValueSource(ints = {1, 2, 3, 5, 10, 100})\n    void shouldReturnZeroForZeroToAnyPositivePower(int exponent) {\n        assertEquals(0, calculator.power(0, exponent));\n    }\n    \n    @Test\n    void shouldReturnOneForZeroToZeroPower() {\n        assertEquals(1, calculator.power(0, 0));\n    }\n    \n    @ParameterizedTest\n    @CsvSource({\n        \"2, 1, 2\",\n        \"3, 2, 9\",\n        \"4, 3, 64\",\n        \"10, 2, 100\",\n        \"-2, 2, 4\",\n        \"-2, 3, -8\",\n        \"-3, 4, 81\",\n        \"-3, 3, -27\"\n    })\n    void shouldCalculatePowerCorrectly(int base, int exponent, int expected) {\n        assertEquals(expected, calculator.power(base, exponent));\n    }\n    \n    @Test\n    void shouldHandleNegativeBaseWithEvenExponent() {\n        assertEquals(4, calculator.power(-2, 2));\n        assertEquals(16, calculator.power(-2, 4));\n    }\n    \n    @Test\n    void shouldHandleNegativeBaseWithOddExponent() {\n        assertEquals(-8, calculator.power(-2, 3));\n        assertEquals(-32, calculator.power(-2, 5));\n    }\n    \n    @Test\n    void shouldHandleLargeExponents() {\n        assertEquals(1024, calculator.power(2, 10));\n        assertEquals(1, calculator.power(1, Integer.MAX_VALUE));\n    }\n    \n    @Test\n    void shouldHandleIntegerOverflowNaturally() {\n        // Test cases that would overflow - behavior depends on implementation\n        // but should not throw exceptions for valid non-negative exponents\n        assertDoesNotThrow(() -> calculator.power(2, 31));\n        assertDoesNotThrow(() -> calculator.power(10, 10));\n    }\n    \n    @ParameterizedTest\n    @ValueSource(ints = {Integer.MIN_VALUE, -1000, -50, -1})\n    void shouldRejectAllNegativeExponentsWithProperMessage(int negativeExponent) {\n        IllegalArgumentException exception = assertThrows(\n            IllegalArgumentException.class,\n            () -> calculator.power(0, negativeExponent)\n        );\n        assertTrue(exception.getMessage().toLowerCase().contains(\"negative\"));\n    }\n}\n```",
