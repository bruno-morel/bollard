acade;\\nimport com.example.core.Calculator;\\n\\nit('computePower delegates to Calculator.power for negative exponents', () -> {\\n  CalculatorFacade facade = new CalculatorFacade();\\n  Calculator calculator = new Calculator();\\n  \\n  double facadeResult = facade.computePower(2, -3);\\n  double calculatorResult = calculator.power(2, -3);\\n  \\n  assertEquals(calculatorResult, facadeResult, 0.001);\\n  assertEquals(0.125, facadeResult, 0.001);\\n})\"\n    },\n    {\n      \"id\": \"c3\",\n      \"concern\": \"resilience\",\n      \"claim\": \"CalculatorFacade.computePower propagates IllegalArgumentException from Calculator.power when base is 0 and exponent is negative\",\n      \"grounding\": [\n        {\n          \"quote\": \"public double computePower(int base, int exponent) { ... }\",\n          \"source\": \"signature:CalculatorFacade.computePower\"\n        },\n        {\n          \"quote\": \"public double power(int base, int exponent) { ... }\",\n          \"source\": \"signature:Calculator.power\"\n        },\n        {\n          \"quote\": \"import com.example.core.Calculator;\",\n          \"source\": \"edge:api->core\"\n        }\n      ],\n      \"test\": \"import com.example.api.CalculatorFacade;\\nimport com.example.core.Calculator;\\n\\nit('computePower propagates IllegalArgumentException from Calculator.power', () -> {\\n  CalculatorFacade facade = new CalculatorFacade();\\n  Calculator calculator = new Calculator();\\n  \\n  assertThrows(IllegalArgumentException.class, () -> calculator.power(0, -1));\\n  assertThrows(IllegalArgumentException.class, () -> facade.computePower(0, -1));\\n})\"\n    },\n    {\n      \"id\": \"c4\",\n      \"concern\": \"correctness\",\n      \"claim\": \"CalculatorFacade.computePower handles edge cases consistently with Calculator.power for zero base and positive exponent\",\n      \"grounding\": [\n        {\n          \"quote\": \"public double computePower(int base, int exponent) { ... }\",\n          \"source