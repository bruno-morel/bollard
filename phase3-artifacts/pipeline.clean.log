      "data": "```java\npackage com.example.core;\n\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.params.ParameterizedTest;\nimport org.junit.jupiter.params.provider.CsvSource;\nimport org.junit.jupiter.params.provider.ValueSource;\nimport static org.junit.jupiter.api.Assertions.*;\n\npublic class CalculatorAdversarialTest {\n    \n    private Calculator calculator;\n    \n    @BeforeEach\n    void setUp() {\n        calculator = new Calculator();\n    }\n    \n    // Acceptance Criteria Tests\n    @Test\n    void shouldCalculatePowerForPositiveExponent() {\n        assertEquals(8.0, calculator.power(2, 3), 0.0001);\n    }\n    \n    @Test\n    void shouldCalculatePowerForNegativeExponent() {\n        assertEquals(0.125, calculator.power(2, -3), 0.0001);\n    }\n    \n    @Test\n    void shouldThrowExceptionForZeroBaseNegativeExponent() {\n        IllegalArgumentException exception = assertThrows(\n            IllegalArgumentException.class,\n            () -> calculator.power(0, -1)\n        );\n        assertNotNull(exception.getMessage());\n    }\n    \n    @Test\n    void shouldReturnZeroForZeroBasePositiveExponent() {\n        assertEquals(0.0, calculator.power(0, 5), 0.0001);\n    }\n    \n    @Test\n    void shouldReturnOneForAnyBaseZeroExponent() {\n        assertEquals(1.0, calculator.power(5, 0), 0.0001);\n    }\n    \n    // Edge Cases - Zero exponent\n    @ParameterizedTest\n    @ValueSource(ints = {-100, -1, 0, 1, 100, Integer.MAX_VALUE, Integer.MIN_VALUE})\n    void shouldReturnOneForZeroExponent(int base) {\n        assertEquals(1.0, calculator.power(base, 0), 0.0001);\n    }\n    \n    // Edge Cases - Zero base\n    @ParameterizedTest\n    @ValueSource(ints = {1, 2, 10, 100, Integer.MAX_VALUE})\n    void shouldReturnZeroForZeroBasePositiveExponent(int exponent) {\n        assertEquals(0.0, calculator.power(0, exponent), 0.0001);\n    }\n    \n    @ParameterizedTest\n    @ValueSource(ints = {-1, -2, -10, -100, Integer.MIN_VALUE})\n    void shouldThrowForZeroBaseNegativeExponent(int exponent) {\n        assertThrows(IllegalArgumentException.class, () -> calculator.power(0, exponent));\n    }\n    \n    // Negative base tests - odd vs even exponents\n    @Test\n    void shouldHandleNegativeBaseOddExponent() {\n        assertEquals(-8.0, calculator.power(-2, 3), 0.0001);\n        assertEquals(-32.0, calculator.power(-2, 5), 0.0001);\n    }\n    \n    @Test\n    void shouldHandleNegativeBaseEvenExponent() {\n        assertEquals(4.0, calculator.power(-2, 2), 0.0001);\n        assertEquals(16.0, calculator.power(-2, 4), 0.0001);\n    }\n    \n    @Test\n    void shouldHandleNegativeBaseNegativeOddExponent() {\n        assertEquals(-0.125, calculator.power(-2, -3), 0.0001);\n    }\n    \n    @Test\n    void shouldHandleNegativeBaseNegativeEvenExponent() {\n        assertEquals(0.25, calculator.power(-2, -2), 0.0001);\n    }\n    \n    // Boundary value tests\n    @ParameterizedTest\n    @CsvSource({\n        \"1, 1000, 1.0\",\n        \"1, -1000, 1.0\",\n        \"-1, 2, 1.0\",\n        \"-1, 3, -1.0\",\n        \"2, 1, 2.0\",\n        \"10, 2, 100.0\"\n    })\n    void shouldHandleBoundaryValues(int base, int exponent, double expected) {\n        assertEquals(expected, calculator.power(base, exponent), 0.0001);\n    }\n    \n    // Large exponent tests\n    @Test\n    void shouldHandleLargePositiveExponent() {\n        assertEquals(1024.0, calculator.power(2, 10), 0.0001);\n    }\n    \n    @Test\n    void shouldHandleLargeNegativeExponent() {\n        assertEquals(1.0/1024.0, calculator.power(2, -10), 0.0001);\n    }\n    \n    // Property-based invariants\n    @ParameterizedTest\n    @ValueSource(ints = {-10, -5, -2, -1, 1, 2, 5, 10})\n    void shouldSatisfyPowerInverse(int base) {\n        if (base != 0) {\n            double result = calculator.power(base, 3);\n            double inverse = calculator.power(base, -3);\n            assertEquals(1.0, result * inverse, 0.0001);\n        }\n    }\n    \n    @ParameterizedTest\n    @ValueSource(ints = {-5, -2, 2, 3, 5})\n    void shouldSatisfyPowerMultiplication(int base) {\n        double power2 = calculator.power(base, 2);\n        double power3 = calculator.power(base, 3);\n        double power5 = calculator.power(base, 5);\n        assertEquals(power5, power2 * power3, 0.0001);\n    }\n    \n    // Type safety - return type must be double\n    @Test\n    void shouldReturnDoubleType() {\n        Object result = calculator.power(2, 3);\n        assertTrue(result instanceof Double);\n    }\n    \n    // Precision tests for fractional results\n    @Test\n    void shouldMaintainPrecisionForFractionalResults() {\n        assertEquals(1.0/3.0, calculator.power(3, -1), 0.0001);\n        assertEquals(1.0/9.0, calculator.power(3, -2), 0.0001);\n        assertEquals(1.0/27.0, calculator.power(3, -3), 0.0001);\n    }\n}\n```",
      "cost_usd": 0.03297,
      "duration_ms": 19318
    },
