      "status": "ok",
      "data": "```java\npackage com.example.core;\n\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.params.ParameterizedTest;\nimport org.junit.jupiter.params.provider.ValueSource;\nimport org.junit.jupiter.params.provider.CsvSource;\nimport static org.junit.jupiter.api.Assertions.*;\n\npublic class CalculatorAdversarialTest {\n\n    @Test\n    void powerShouldReturnCorrectResultForPositiveBaseAndExponent() {\n        Calculator calculator = new Calculator();\n        assertEquals(8, calculator.power(2, 3));\n    }\n\n    @Test\n    void powerShouldReturnOneForAnyBaseWithZeroExponent() {\n        Calculator calculator = new Calculator();\n        assertEquals(1, calculator.power(5, 0));\n        assertEquals(1, calculator.power(0, 0));\n        assertEquals(1, calculator.power(-3, 0));\n        assertEquals(1, calculator.power(Integer.MAX_VALUE, 0));\n    }\n\n    @Test\n    void powerShouldReturnZeroForZeroBaseWithPositiveExponent() {\n        Calculator calculator = new Calculator();\n        assertEquals(0, calculator.power(0, 5));\n        assertEquals(0, calculator.power(0, 1));\n        assertEquals(0, calculator.power(0, Integer.MAX_VALUE));\n    }\n\n    @Test\n    void powerShouldReturnOneForOneToAnyPositiveExponent() {\n        Calculator calculator = new Calculator();\n        assertEquals(1, calculator.power(1, 100));\n        assertEquals(1, calculator.power(1, 1));\n        assertEquals(1, calculator.power(1, Integer.MAX_VALUE));\n    }\n\n    @Test\n    void powerShouldThrowIllegalArgumentExceptionForNegativeExponent() {\n        Calculator calculator = new Calculator();\n        IllegalArgumentException exception = assertThrows(IllegalArgumentException.class, \n            () -> calculator.power(2, -1));\n        assertTrue(exception.getMessage().contains(\"negative\"));\n    }\n\n    @ParameterizedTest\n    @ValueSource(ints = {-1, -2, -10, -100, Integer.MIN_VALUE})\n    void powerShouldThrowIllegalArgumentExceptionForAllNegativeExponents(int negativeExponent) {\n        Calculator calculator = new Calculator();\n        IllegalArgumentException exception = assertThrows(IllegalArgumentException.class,\n            () -> calculator.power(5, negativeExponent));\n        assertTrue(exception.getMessage().contains(\"negative\"));\n    }\n\n    @Test\n    void powerShouldHandleNegativeBaseWithEvenExponent() {\n        Calculator calculator = new Calculator();\n        assertEquals(4, calculator.power(-2, 2));\n        assertEquals(16, calculator.power(-2, 4));\n    }\n\n    @Test\n    void powerShouldHandleNegativeBaseWithOddExponent() {\n        Calculator calculator = new Calculator();\n        assertEquals(-8, calculator.power(-2, 3));\n        assertEquals(-32, calculator.power(-2, 5));\n    }\n\n    @ParameterizedTest\n    @CsvSource({\n        \"2, 1, 2\",\n        \"3, 2, 9\",\n        \"4, 3, 64\",\n        \"10, 2, 100\",\n        \"-3, 2, 9\",\n        \"-3, 3, -27\"\n    })\n    void powerShouldReturnCorrectResultsForVariousInputs(int base, int exponent, int expected) {\n        Calculator calculator = new Calculator();\n        assertEquals(expected, calculator.power(base, exponent));\n    }\n\n    @Test\n    void powerShouldHandleLargeExponents() {\n        Calculator calculator = new Calculator();\n        assertEquals(1024, calculator.power(2, 10));\n        assertEquals(1, calculator.power(-1, 100));\n        assertEquals(-1, calculator.power(-1, 101));\n    }\n\n    @Test\n    void powerShouldHandleIntegerOverflowGracefully() {\n        Calculator calculator = new Calculator();\n        // Test with values that would overflow - behavior depends on implementation\n        // but should not throw for non-negative exponents\n        assertDoesNotThrow(() -> calculator.power(Integer.MAX_VALUE, 2));\n        assertDoesNotThrow(() -> calculator.power(1000, 10));\n    }\n\n    @Test\n    void powerShouldThrowForNegativeExponentWithZeroBase() {\n        Calculator calculator = new Calculator();\n        IllegalArgumentException exception = assertThrows(IllegalArgumentException.class,\n            () -> calculator.power(0, -1));\n        assertTrue(exception.getMessage().contains(\"negative\"));\n    }\n\n    @Test\n    void powerShouldThrowForNegativeExponentWithNegativeBase() {\n        Calculator calculator = new Calculator();\n        IllegalArgumentException exception = assertThrows(IllegalArgumentException.class,\n            () -> calculator.power(-5, -2));\n        assertTrue(exception.getMessage().contains(\"negative\"));\n    }\n}\n```",
