      "status": "ok",
      "data": "```json\n{\n  \"claims\": [\n    {\n      \"id\": \"c1\",\n      \"concern\": \"correctness\",\n      \"claim\": \"CalculatorFacade can invoke Calculator.power with valid arguments and receive correct results\",\n      \"grounding\": [\n        {\n          \"quote\": \"public int power(int base, int exponent) { ... }\",\n          \"source\": \"signature:Calculator.power\"\n        },\n        {\n          \"quote\": \"import com.example.core.Calculator;\",\n          \"source\": \"edge:api->core imports\"\n        }\n      ],\n      \"test\": \"import com.example.core.Calculator;\\nimport com.example.api.CalculatorFacade;\\n\\nit('CalculatorFacade can use Calculator.power for valid inputs', () -> {\\n  Calculator calc = new Calculator();\\n  assertEquals(8, calc.power(2, 3));\\n  assertEquals(1, calc.power(5, 0));\\n  assertEquals(0, calc.power(0, 5));\\n  assertEquals(1, calc.power(1, 100));\\n})\"\n    },\n    {\n      \"id\": \"c2\",\n      \"concern\": \"resilience\",\n      \"claim\": \"CalculatorFacade must handle IllegalArgumentException from Calculator.power when negative exponents are passed\",\n      \"grounding\": [\n        {\n          \"quote\": \"public int power(int base, int exponent) { ... }\",\n          \"source\": \"signature:Calculator.power\"\n        },\n        {\n          \"quote\": \"\\\"providerErrors\\\": []\",\n          \"source\": \"edge:api->core providerErrors\"\n        },\n        {\n          \"quote\": \"\\\"consumerCatches\\\": []\",\n          \"source\": \"edge:api->core consumerCatches\"\n        }\n      ],\n      \"test\": \"import com.example.core.Calculator;\\nimport com.example.api.CalculatorFacade;\\n\\nit('CalculatorFacade handles IllegalArgumentException from Calculator.power', () -> {\\n  Calculator calc = new Calculator();\\n  assertThrows(IllegalArgumentException.class, () -> {\\n    calc.power(2, -1);\\n  });\\n  \\n  try {\\n    calc.power(5, -3);\\n    fail(\\\"Expected IllegalArgumentException\\\");\\n  } catch (IllegalArgumentException e) {\\n    assertTrue(e.getMessage().contains(\\\"negative\\\"));\\n  }\\n})\"\n    },\n    {\n      \"id\": \"c3\",\n      \"concern\": \"correctness\",\n      \"claim\": \"CalculatorFacade.compute method can delegate power operations to Calculator.power\",\n      \"grounding\": [\n        {\n          \"quote\": \"public int compute(String op, int a, int b) { ... }\",\n          \"source\": \"signature:CalculatorFacade.compute\"\n        },\n        {\n          \"quote\": \"public int power(int base, int exponent) { ... }\",\n          \"source\": \"signature:Calculator.power\"\n        },\n        {\n          \"quote\": \"import com.example.core.Calculator;\",\n          \"source\": \"edge:api->core imports\"\n        }\n      ],\n      \"test\": \"import com.example.core.Calculator;\\nimport com.example.api.CalculatorFacade;\\n\\nit('CalculatorFacade.compute can handle power operations', () -> {\\n  CalculatorFacade facade = new CalculatorFacade();\\n  // Assuming compute method supports \\\"power\\\" operation\\n  assertEquals(8, facade.compute(\\\"power\\\", 2, 3));\\n  assertEquals(1, facade.compute(\\\"power\\\", 7, 0));\\n  assertEquals(0, facade.compute(\\\"power\\\", 0, 10));\\n})\"\n    },\n    {\n      \"id\": \"c4\",\n      \"concern\": \"performance\",\n      \"claim\": \"Calculator.power method performs efficiently for reasonable exponent values without causing performance degradation in CalculatorFacade\",\n      \"grounding\": [\n        {\n          \"quote\": \"public int power(int base, int exponent) { ... }\",\n          \"source\": \"signature:Calculator.power\"\n        },\n        {\n          \"quote\": \"public int compute(String op, int a, int b) { ... }\",\n          \"source\": \"signature:CalculatorFacade.compute\"\n        }\n      ],\n      \"test\": \"import com.example.core.Calculator;\\nimport com.example.api.CalculatorFacade;\\n\\nit('Calculator.power performs efficiently for moderate exponents', () -> {\\n  Calculator calc = new Calculator();\\n  long startTime = System.nanoTime();\\n  \\n  // Test multiple power operations\\n  for (int i = 0; i < 1000; i++) {\\n    calc.power(2, 10);\\n    calc.power(3, 5);\\n    calc.power(5, 3);\\n  }\\n  \\n  long duration = System.nanoTime() - startTime;\\n  // Should complete within reasonable time (1 second)\\n  assertTrue(duration < 1_000_000_000L);\\n})\"\n    }\n  ]\n}\n```",
