{
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "mutate": [
    "**/*.ts",
    "**/*.tsx",
    "!**/node_modules/**",
    "!**/dist/**",
    "!**/*.test.ts",
    "!**/*.spec.ts",
    "!**/__tests__/**"
  ],
  "reporters": [
    "json",
    "clear-text"
  ],
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  },
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  },
  "concurrency": 2,
  "timeoutMS": 300000
}