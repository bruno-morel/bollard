{
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "mutate": [
    "packages/engine/src/cost-tracker.ts"
  ],
  "reporters": [
    "json",
    "clear-text"
  ],
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  },
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  },
  "concurrency": 2,
  "timeoutMS": 300000
}